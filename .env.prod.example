# ================================================================
# ix-copilot — Production Environment (Vendor Cloud VM)
#
# Copy this file on your VM:  cp .env.prod.example .env
# Fill in all values, then:   docker compose up -d
# ================================================================

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<STRONG_PASSWORD>@postgres:5432/ix_db?schema=public

# ── Auth Secrets ────────────────────────────────────────────────
JWT_SECRET=<GENERATE_A_64_CHAR_RANDOM_STRING>
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7

# ── SMTP (Real email delivery) ────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=IX Platform <noreply@yourdomain.com>

# ── Application ────────────────────────────────────────────────
APP_URL=https://admin.yourdomain.com
NODE_ENV=production
