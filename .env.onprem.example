# ================================================================
# On-Prem Environment Variables — Template
#
# Copy this file:  cp .env.onprem.example .env.onprem
# Then fill in the values below.
#
# This file is used by: delivery-package/docker-compose.yml
# ================================================================

# ── External Infrastructure ───────────────────────────────────────
# Set to true if you have your own PostgreSQL / Redis (not in Docker).
# When true, the corresponding Docker container will NOT start.
# Default: false (both run in Docker)
EXTERNAL_DB=false
EXTERNAL_REDIS=false

# ── Database ────────────────────────────────────────────────────
# When EXTERNAL_DB=false (default):
#   POSTGRES_PASSWORD is used by the Docker postgres container.
#   DATABASE_URL hostname must be "postgres" (the Docker service name).
#   Example: postgresql://postgres:MyStrongPass@postgres:5432/arc_db?schema=public
#
# When EXTERNAL_DB=true:
#   POSTGRES_PASSWORD is ignored (your external DB manages its own auth).
#   DATABASE_URL must point to your PostgreSQL server.
#   Example: postgresql://myuser:mypass@192.168.1.50:5432/arc_db?schema=public
#
#   Requirements for external PostgreSQL:
#     - PostgreSQL 15 or higher
#     - The database must already exist (we run migrations, NOT CREATE DATABASE)
#     - The DB user must have full DDL permissions (CREATE TABLE, ALTER TABLE, CREATE INDEX, etc.)
#     - PostgreSQL must accept connections from Docker containers
#       (check pg_hba.conf and firewall rules)
#     - On macOS/Windows: use "host.docker.internal" as the hostname
#       if PostgreSQL runs on the same machine as Docker
#     - On Linux: use the host's IP address (not localhost/127.0.0.1)
#       or run Docker with --network host
POSTGRES_PASSWORD=<set-a-strong-password>
DATABASE_URL=postgresql://postgres:<same-password-as-above>@postgres:5432/arc_db?schema=public

# ── Redis ────────────────────────────────────────────────────────
# When EXTERNAL_REDIS=false (default): uses Docker redis container.
#   REDIS_HOST defaults to "redis" (Docker service name). No change needed.
#
# When EXTERNAL_REDIS=true: set these to your Redis server.
#   Example: REDIS_HOST=192.168.1.50  REDIS_PORT=6379
REDIS_HOST=redis
REDIS_PORT=6379

# ── Auth Service Secrets ────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=<generate-a-strong-secret>
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7

# ── On-Prem License ────────────────────────────────────────────
# Public key (Base64-encoded) — provided by vendor
# Used for license validation only (NOT for license generation)
ONPREM_LICENSE_PUBLIC_KEY=<provided-by-vendor>

# ── Tenant & Admin ──────────────────────────────────────────────
# TENANT_ID must match the license file — do not change unless regenerating the license
TENANT_ID=1
TENANT_NAME=My Organization
TENANT_DOMAIN=onprem.local
ADMIN_EMAIL=admin@onprem.local
ADMIN_PASSWORD=<set-a-strong-password>
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ── Application URL ─────────────────────────────────────────────
# Public URL of the admin portal (used in welcome emails)
APP_URL=http://localhost:3000

# ── SMTP (Email) ────────────────────────────────────────────────
# Required for welcome emails, password resets, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IX Platform <noreply@example.com>

# ── Docker Registry ────────────────────────────────────────────
# Registry URL where pre-built images are hosted
REGISTRY=local
# Image version tag — update this when upgrading
IMAGE_TAG=latest
