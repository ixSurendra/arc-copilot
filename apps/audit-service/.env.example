# Audit-service runs on a dedicated database (arc_audit_db) to keep its
# huge AuditLog + NotificationLog tables off the foundation's lock /
# vacuum / backup paths.
#
# Local dev: copy to apps/audit-service/.env and override DATABASE_URL.
# Docker:    .env.docker carries AUDIT_DATABASE_URL which docker-compose
#            wires into this service as DATABASE_URL.
DATABASE_URL="postgresql://user:password@localhost:5432/arc_audit_db?schema=public"
