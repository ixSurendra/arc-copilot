{
  "name": "@arc/users-service",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "users-service",
    "targets": {
      "build": {
        "dependsOn": [
          "prisma:generate"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/users-service"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prisma:generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm prisma generate",
          "cwd": "apps/users-service"
        }
      },
      "prisma:migrate:dev": {
        "executor": "nx:run-commands",
        "options": {
          "command": "[ \"$NODE_ENV\" != 'production' ] && pnpm prisma migrate dev || echo 'ERROR: prisma migrate dev is not allowed in production. Use prisma:migrate:deploy instead.' && exit 1",
          "cwd": "apps/users-service"
        }
      },
      "prisma:migrate:deploy": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm prisma migrate deploy",
          "cwd": "apps/users-service"
        }
      },
      "prisma:studio": {
        "executor": "nx:run-commands",
        "options": {
          "command": "[ \"$NODE_ENV\" != 'production' ] && pnpm prisma studio || echo 'ERROR: prisma studio is not allowed in production.' && exit 1",
          "cwd": "apps/users-service"
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/users-service/dist/package.json",
          "{workspaceRoot}/apps/users-service/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/users-service/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "users-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "users-service:build:development"
          },
          "production": {
            "buildTarget": "users-service:build:production"
          }
        }
      }
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@arc/shared": "workspace:*",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {}
}
