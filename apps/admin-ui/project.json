{
  "name": "@arc/admin-ui",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin-ui",
        "command": "next build --webpack"
      },
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^production",
        { "externalDependencies": ["next"] }
      ],
      "outputs": [
        "{projectRoot}/.next/!(cache)/**/*",
        "{projectRoot}/.next/!(cache)"
      ]
    },
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "apps/admin-ui",
        "command": "next dev --webpack"
      }
    }
  }
}
