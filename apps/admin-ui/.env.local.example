# BFF URL (server-side only, never exposed to browser)
BFF_INTERNAL_URL=http://localhost:6006

# Public app URL (for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cookie settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Cloud feature flag — pricing / quota / usage UIs.
# Default off in the on-prem build; flip to "true" only for a cloud SKU.
# Hides the items from sidebar + mobile-nav and gates the routes with
# notFound() so direct URLs don't sneak in.
NEXT_PUBLIC_ARC_CLOUD_FEATURES_ENABLED=false
