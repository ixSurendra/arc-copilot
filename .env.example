# Foundation services (auth, users, tenant, license) — share arc_db.
DATABASE_URL="postgresql://user:password@localhost:5432/arc_db?schema=public"

# Audit-service runs on its own database for operational isolation
# (huge AuditLog + NotificationLog tables don't touch foundation
# vacuum / backup / lock paths). Both DBs live on the same Postgres
# instance — the bootstrap script in docker/postgres/init-databases.sh
# creates arc_audit_db on first boot.
#
# Local dev: each service reads DATABASE_URL from its own .env file;
# audit-service overrides this URL in apps/audit-service/.env.
AUDIT_DATABASE_URL="postgresql://user:password@localhost:5432/arc_audit_db?schema=public"

# arc-insights backend (added in Phase 2 of the build) — its own DB.
INSIGHTS_DATABASE_URL="postgresql://user:password@localhost:5432/arc_insights_db?schema=public"
