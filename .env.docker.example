# ================================================================
# Docker environment variables — Template
# Copy this file:  cp .env.docker.example .env.docker
# Then fill in the secret values below
# ================================================================

# Override NODE_ENV so Swagger is accessible in local Docker
NODE_ENV=development

# Databases — one PostgreSQL container, three databases (created by
# docker/postgres/init-databases.sh on first boot).
#
# DATABASE_URL          foundation services (auth, users, tenant, license)
# AUDIT_DATABASE_URL    wired into audit-service as its own DATABASE_URL
# INSIGHTS_DATABASE_URL reserved for the arc-insights backend (added later)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/arc_db?schema=public
AUDIT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/arc_audit_db?schema=public
INSIGHTS_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/arc_insights_db?schema=public

# Auth service secrets
JWT_SECRET=<generate-a-strong-secret>
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7

# Service-to-service communication (Docker hostnames)
TENANT_SERVICE_HOST=tenant-service
USERS_SERVICE_HOST=users-service
LICENSE_SERVICE_HOST=license-service
AUTH_SERVICE_HOST=auth-service
AUDIT_SERVICE_HOST=audit-service
ADMIN_PORTAL_HOST=admin-portal

# Frontend (admin-ui connects to BFF internally)
BFF_INTERNAL_URL=http://admin-portal:6006

# SMTP (MailPit dev mail catcher — Web UI at http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IX Platform <noreply@ix-copilot.local>

# On-prem mode (set to 'true' for on-premise deployments)
# ON_PREM=false

# Super admin seed (used by tools/seed-super-admin.ts)
# SUPER_ADMIN_EMAIL=admin@system.local
# SUPER_ADMIN_PASSWORD=ChangeMe123!

# On-prem license signing — both keys live here in dev so the same
# compose stack can act as "cloud" (issue .lic files) and verify them.
# Generate fresh values once with:  bun run tools/generate-license-keys.ts
# That script prints both base64 strings; paste them here.
# Production split: PRIVATE goes only on the cloud admin-portal box;
# PUBLIC ships in every on-prem deployment.
ONPREM_LICENSE_PRIVATE_KEY=<base64 of tools/keys/private.pem — see tools/generate-license-keys.ts>
ONPREM_LICENSE_PUBLIC_KEY=<base64 of tools/keys/public.pem — see tools/generate-license-keys.ts>
