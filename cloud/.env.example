# ================================================================
# ix-copilot Cloud — Environment Configuration
# ================================================================
# Copy this file to .env and fill in the values before deploying.
# cp .env.example .env

# ── Registry ────────────────────────────────────────────────────
# GHCR: ghcr.io/your-org
# Local: local
REGISTRY=local
IMAGE_TAG=latest

# ── Database ────────────────────────────────────────────────────
# For cloud: point to your managed PostgreSQL (RDS, Cloud SQL, etc.)
# For EC2 with native PostgreSQL: use host IP
DATABASE_URL=postgresql://ixadmin:password@172.31.14.75:5432/arc_db?schema=public

# ── Redis ────────────────────────────────────────────────────────
# For cloud: point to your managed Redis (ElastiCache, etc.)
# For EC2 with native Redis: use Docker bridge IP
REDIS_HOST=172.17.0.1
REDIS_PORT=6379

# ── Auth Secrets ────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-secure-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7

# ── Super Admin (first time setup) ──────────────────────────────
# Used by the seed service on first deploy — safe to remove after
SUPER_ADMIN_EMAIL=admin@innovatechs.ai
SUPER_ADMIN_PASSWORD=ChangeMe123!

# ── Application URL ──────────────────────────────────────────────
APP_URL=http://13.127.14.176:3000

# ── SMTP (Email) ─────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=unifiedplatform@innovatechs.com
SMTP_PASS=your-smtp-password
SMTP_FROM=unifiedplatform@innovatechs.com
